# POLYSEER Environment Configuration
# Copy this file to .env and fill in your actual values

# =========================
# API KEYS
# =========================

# Required: OpenAI API key for LangChain agents
OPENAI_API_KEY=sk-...

# Required: Valyu AI API key for deep web research
VALYU_API_KEY=...

# =========================
# DATABASE & MEMORY
# =========================

# Required: Supabase configuration for data persistence
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJhbGc...
SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_KEY=...

# Memory backend configuration
MEMORY_BACKEND=postgresql
ENABLE_MEMORY_PERSISTENCE=true

# =========================
# PREDICTION MARKET APIs
# =========================

# Optional: Kalshi API credentials (for trading)
KALSHI_API_KEY_ID=...
KALSHI_API_KEY=...
KALSHI_PRIVATE_KEY_PATH=./keys/kalshi_private_key.pem
KALSHI_API_URL=https://api.elections.kalshi.com/trade-api/v2

# Optional: Polymarket credentials (for trading)
POLYMARKET_PRIVATE_KEY=...
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com

# =========================
# RISK MANAGEMENT
# =========================

# Default bankroll for position sizing
DEFAULT_BANKROLL=10000.0

# Maximum Kelly fraction (% of bankroll per bet)
MAX_KELLY_FRACTION=0.05

# Minimum edge threshold for arbitrage opportunities
MIN_EDGE_THRESHOLD=0.02

# Risk-free rate for calculations
RISK_FREE_RATE=0.02

# Confidence level for risk calculations
CONFIDENCE_LEVEL=0.95

# =========================
# APPLICATION SETTINGS
# =========================

# Environment: development | staging | production
ENVIRONMENT=development

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# =========================
# API SERVER (Optional)
# =========================

API_HOST=0.0.0.0
API_PORT=8000

# =========================
# LANGSMITH (Optional)
# =========================

# LangSmith tracing for debugging
LANGSMITH_API_KEY=...
LANGSMITH_PROJECT=polyseer
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
